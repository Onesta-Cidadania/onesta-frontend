# Supabase Configuration
# Copie este arquivo para .env.local e preencha com suas credenciais do Supabase
# Para obter essas credenciais, acesse: https://supabase.com/dashboard

# Supabase URL - Encontrado em Settings > API
VITE_SUPABASE_URL=your-project-url.supabase.co

# Supabase Anon Key - Chave pública para acesso do cliente
# Encontrado em Settings > API
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# URL pública da aplicação - usada nos redirects de autenticação
VITE_APP_URL=https://www.onestacidadania.com.br
